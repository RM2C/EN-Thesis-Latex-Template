% Change the fonts and styles of chapter and section titles
\usepackage{titlesec}
% Change the chapter font and style
\titleformat{\chapter}%
    [block]%
    {\sffamily\bfseries\huge}%
    {Chapter \thechapter}%
    {1.0em}%
    {\rmfamily}%
\titlespacing{\chapter}
    {0pt}%
    {18pt}%
    {34pt}%
% Change the section font and style
% \titleformat*{\section}{\Large\bfseries\sffamily}
\titleformat{\section}%
    [block]%
    {\sffamily\Large\bfseries}%
    {\thesection}%
    {1.0em}%
    {\rmfamily}%
% Change the subsection font and style
% \titleformat*{\subsection}{\large\bfseries\sffamily}
\titleformat{\subsection}%
    [block]%
    {\sffamily\large\bfseries}%
    {\thesubsection}%
    {1.0em}%
    {\rmfamily}%
% Change the subsubsection font and style
% \titleformat*{\subsubsection}{\normalsize\bfseries\sffamily}
\titleformat{\subsubsection}%
    [block]%
    {\sffamily\normalsize\bfseries}%
    {\thesubsubsection}%
    {1.0em}%
    {\rmfamily}%

% Change the fonts and styles of chapter and section titles in the table of contents
\usepackage{titletoc}
\titlecontents{chapter}
[0em] % Left spacing
{\vskip8pt\bfseries} % Executed before the entry
% {\vskip8pt} % Executed before the entry
{{\sffamily\thecontentslabel}\hspace{0.8em}}
{\hspace{.0em}}
{\hfill\contentspage}
[\vskip 0pt] % Executed after the entry

\titlecontents{section}
[1.6em] % Left spacing
{} % Executed before the entry
{{\sffamily\thecontentslabel}\hspace{1.0em}}
{} % Format for unnumbered entries
{\dotfill\contentspage}
[\vskip 0pt] % Executed after the entry

\titlecontents{subsection}
[2.6em] % Left spacing
{} % Executed before the entry
{{\sffamily\thecontentslabel}\hspace{1.0em}}
{} % Format for unnumbered entries
{\dotfill\contentspage}
[\vskip 0pt] % Executed after the entry

