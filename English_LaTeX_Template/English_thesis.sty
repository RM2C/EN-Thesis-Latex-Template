\renewcommand{\floatpagefraction}{.9}
\setcounter{totalnumber}{10}
\setcounter{topnumber}{10}
\setcounter{bottomnumber}{10}

\renewcommand{\figurename}{\textbf{Figure}}
\renewcommand{\tablename}{\textbf{Table}}

\newcommand{\figref}[1]{\normalsize \textsf{Figure~\ref{#1}}}
\newcommand{\tabref}[1]{\normalsize \textsf{Table~\ref{#1}}}

\newcommand{\eqrefer}[1]{\normalsize \textsf{Eq.~\eqref{#1}}}

\def\maketitle{
\begin{titlepage}

\vbox to\coverheight{%
\begin{center}
{\huge \@year\par} \vskip 3.5em
{\Huge \@degree \par} \vskip 6.5em
{{\sffamily\bfseries\Huge \@title\par}}
\vfil
\begin{tabular}{rl}
{\Large ACADEMIC SUPERVISORS:}& {{\LARGE \@teacher}} \\ \\
\end{tabular}\\
\vfil
{\LARGE \@affiliationlineone\\}
\vskip 0.4em
{\LARGE \@affiliationlinetwo\\}
\vskip 0.4em
{\LARGE \@affiliationlinethree\\}

\begin{tabular}{rl}
\\ \\
{\large STUDENT ID:}& {{\LARGE \@IDcode}} \\ \\
{\large NAME:}& {{\LARGE \@author }}\\ \\
\end{tabular}\\
\end{center}
}

\end{titlepage}

\let\maketitle\relax}

\def\abstract{
    \titlepage
    %\null\vfil
    \begin{flushleft}
    % {\LARGE \bf Abstract}
    {\Large \bf Abstract}
    \end{flushleft}}

\def\endabstract{
    \par
    \vfil
    \null
    \endtitlepage}

\providecommand{\keywords}[1]
{
    \vspace{20pt}
    \noindent
    \textbf{Keywords}\\#1
}

\renewcommand{\bibname}{References}

\renewenvironment{thebibliography}[1]
{\section*{\bibname\@mkboth{\bibname}{\bibname}}%
  \list{\@biblabel{\@arabic\c@enumiv}}%
       {\settowidth\labelwidth{\@biblabel{#1}}%
        \leftmargin\labelwidth
        \advance\leftmargin\labelsep
 \setlength\itemsep{-1.5pt}% Adjust this value for spacing between items
 \setlength\baselineskip{16pt}% Adjust this value for line spacing
        \@openbib@code
        \usecounter{enumiv}%
        \let\p@enumiv\@empty
        \renewcommand\theenumiv{\@arabic\c@enumiv}}%
  \sloppy
  \clubpenalty4000
  \@clubpenalty\clubpenalty
  \widowpenalty4000%
  \sfcode`\.\@m}
 {\def\@noitemerr
   {\@latex@warning{Empty `thebibliography' environment}}%
  \endlist}
